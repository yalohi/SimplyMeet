<div class="input-group mt-2">
	<input
		type="text"
		class="form-control bg-secondary text-white border-0"
		readonly=""
		value="@Text"
		autocomplete="off"
		autocorrect="off"
		autocapitalize="off"
		spellcheck="false" />

	<button class="btn btn-primary border-0" type="button" @onclick="OnCopyClick">
		<i class="fas fa-copy"></i>
	</button>
</div>
